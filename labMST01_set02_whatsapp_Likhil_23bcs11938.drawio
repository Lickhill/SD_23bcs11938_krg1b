        <mxCell id="PWeQMWFyox6ZBVBJU6h0-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="question 2&lt;div&gt;design a whatsapp system with proper following requirement&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. user service&lt;/div&gt;&lt;div&gt;2. chat service&lt;/div&gt;&lt;div&gt;3. group service&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;optimize the chat service for handling the millions of request&lt;/div&gt;&lt;div&gt;specify the type of connection used in the design&amp;nbsp;&lt;/div&gt;&lt;div&gt;deterine how the design will be done for LAST SEENfunctionality&lt;/div&gt;&lt;div&gt;implement CDC pipeline in the same architecture&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="470" x="-670" y="-1070" as="geometry" />
        </mxCell>
        <mxCell id="PWeQMWFyox6ZBVBJU6h0-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="schema&lt;div&gt;userid&lt;/div&gt;&lt;div&gt;name&lt;/div&gt;&lt;div&gt;profilepic&lt;/div&gt;&lt;div&gt;bio&lt;/div&gt;&lt;div&gt;phne number&lt;/div&gt;&lt;div&gt;email&lt;/div&gt;&lt;div&gt;groupsID []&lt;/div&gt;&lt;div&gt;communities Joined []&lt;/div&gt;&lt;div&gt;chats[]&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
