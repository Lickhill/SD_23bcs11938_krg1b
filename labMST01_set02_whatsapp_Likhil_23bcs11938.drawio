        </mxCell>
        <mxCell id="PWeQMWFyox6ZBVBJU6h0-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="functional requirement&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. login/register with phone number and opt generation&lt;/div&gt;&lt;div&gt;2. info filling like profile picture, bio&lt;/div&gt;&lt;div&gt;3. findAll() list of users from saved contacts in the whatsapp direct messages list&lt;/div&gt;&lt;div&gt;4. click to open the chat facility of an individual&lt;/div&gt;&lt;div&gt;5. real time(web socket) text functionality&lt;/div&gt;&lt;div&gt;6. single tick for sent from sender device&lt;/div&gt;&lt;div&gt;double tick for received the message by receiver&lt;/div&gt;&lt;div&gt;blue tick for message seen by receiver&lt;/div&gt;&lt;div&gt;7. groups formation and text sharing amoung allthe members of that particular group&lt;/div&gt;&lt;div&gt;8. notification&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="310" x="-580" y="-740" as="geometry" />
        </mxCell>
        <mxCell id="PWeQMWFyox6ZBVBJU6h0-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="non functional requirements&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. rate limiting to avoid spamming of messages&lt;/div&gt;&lt;div&gt;2. scalability for mutiple users using whatsapp at the same time&lt;/div&gt;&lt;div&gt;3.&amp;nbsp; avoid latency in message in case of large amount of members in one group&amp;nbsp;&lt;/div&gt;&lt;div&gt;4. end to end encryptcy&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="310" x="-220" y="-750" as="geometry" />
